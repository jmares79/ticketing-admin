{
    "openapi": "3.0.0",
    "info": {
        "title": "Ticketing Admin API",
        "description": "REST API for ticket listing and statistics.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api/v1",
            "description": "Version 1"
        }
    ],
    "paths": {
        "/stats": {
            "get": {
                "tags": [
                    "Stats"
                ],
                "summary": "Get system-wide ticket statistics",
                "operationId": "getTicketStats",
                "responses": {
                    "200": {
                        "description": "Ticket statistics",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/StatsResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/tickets/open": {
            "get": {
                "tags": [
                    "Tickets"
                ],
                "summary": "Get paginated open tickets",
                "operationId": "getOpenTickets",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Pagination page number",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated list of open tickets",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TicketPaginationResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/tickets/closed": {
            "get": {
                "tags": [
                    "Tickets"
                ],
                "summary": "Get paginated closed tickets",
                "operationId": "getClosedTickets",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Pagination page number",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated list of closed tickets",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TicketPaginationResponse"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/users/{user}/tickets": {
            "get": {
                "tags": [
                    "Users"
                ],
                "summary": "Get paginated tickets for a specific user",
                "operationId": "getUserTickets",
                "parameters": [
                    {
                        "name": "user",
                        "in": "path",
                        "description": "User ID",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "minimum": 1
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Pagination page number",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated list of user tickets",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/TicketPaginationResponse"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "User not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NotFoundError"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "NotFoundError": {
                "required": [
                    "message"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "No query results for model [App\\Models\\User] 100"
                    }
                },
                "type": "object"
            },
            "PaginationLinks": {
                "required": [
                    "first",
                    "last",
                    "prev",
                    "next"
                ],
                "properties": {
                    "first": {
                        "type": "string",
                        "example": "http://localhost:8000/api/v1/tickets/open?page=1",
                        "nullable": true
                    },
                    "last": {
                        "type": "string",
                        "example": "http://localhost:8000/api/v1/tickets/open?page=3",
                        "nullable": true
                    },
                    "prev": {
                        "type": "string",
                        "example": null,
                        "nullable": true
                    },
                    "next": {
                        "type": "string",
                        "example": "http://localhost:8000/api/v1/tickets/open?page=2",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "PaginationMetaLink": {
                "required": [
                    "url",
                    "label",
                    "active"
                ],
                "properties": {
                    "url": {
                        "type": "string",
                        "example": "http://localhost:8000/api/v1/tickets/open?page=1",
                        "nullable": true
                    },
                    "label": {
                        "type": "string",
                        "example": "1"
                    },
                    "active": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "PaginationMeta": {
                "required": [
                    "current_page",
                    "from",
                    "last_page",
                    "links",
                    "path",
                    "per_page",
                    "to",
                    "total"
                ],
                "properties": {
                    "current_page": {
                        "type": "integer",
                        "example": 1
                    },
                    "from": {
                        "type": "integer",
                        "example": 1,
                        "nullable": true
                    },
                    "last_page": {
                        "type": "integer",
                        "example": 3
                    },
                    "links": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/PaginationMetaLink"
                        }
                    },
                    "path": {
                        "type": "string",
                        "example": "http://localhost:8000/api/v1/tickets/open"
                    },
                    "per_page": {
                        "type": "integer",
                        "example": 25
                    },
                    "to": {
                        "type": "integer",
                        "example": 25,
                        "nullable": true
                    },
                    "total": {
                        "type": "integer",
                        "example": 63
                    }
                },
                "type": "object"
            },
            "StatsResponse": {
                "required": [
                    "total_tickets",
                    "open_tickets",
                    "top_user",
                    "last_processed_at"
                ],
                "properties": {
                    "total_tickets": {
                        "type": "integer",
                        "example": 100
                    },
                    "open_tickets": {
                        "type": "integer",
                        "example": 65
                    },
                    "top_user": {
                        "properties": {
                            "name": {
                                "type": "string",
                                "example": "John Doe"
                            },
                            "email": {
                                "type": "string",
                                "format": "email",
                                "example": "john@example.com"
                            }
                        },
                        "type": "object",
                        "nullable": true
                    },
                    "last_processed_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "TicketPaginationResponse": {
                "required": [
                    "data",
                    "links",
                    "meta"
                ],
                "properties": {
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Ticket"
                        }
                    },
                    "links": {
                        "$ref": "#/components/schemas/PaginationLinks"
                    },
                    "meta": {
                        "$ref": "#/components/schemas/PaginationMeta"
                    }
                },
                "type": "object"
            },
            "Ticket": {
                "required": [
                    "id",
                    "subject",
                    "content",
                    "status",
                    "created_at",
                    "updated_at",
                    "user"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 12
                    },
                    "subject": {
                        "type": "string",
                        "example": "Unable to reset password"
                    },
                    "content": {
                        "type": "string",
                        "example": "Reset link is not arriving in my inbox."
                    },
                    "status": {
                        "type": "string",
                        "example": "Open",
                        "enum": [
                            "Open",
                            "InProgress",
                            "Closed"
                        ]
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "user": {
                        "$ref": "#/components/schemas/User"
                    }
                },
                "type": "object"
            },
            "User": {
                "required": [
                    "id",
                    "name",
                    "email"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "john@example.com"
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Tickets",
            "description": "Endpoints for open and closed tickets"
        },
        {
            "name": "Users",
            "description": "Endpoints for user ticket listings"
        },
        {
            "name": "Stats",
            "description": "System-wide ticket statistics"
        }
    ]
}